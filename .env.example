PORT=8080

BLUEPRINT_DB_DATABASE=vanilla_api
BLUEPRINT_DB_USERNAME=postgres
BLUEPRINT_DB_PASSWORD=postgres
BLUEPRINT_DB_HOST=localhost
BLUEPRINT_DB_PORT=5432
BLUEPRINT_DB_SCHEMA=public
BLUEPRINT_DB_SSLMODE=disable
# When set, DATABASE_URL takes precedence over the host/port/database/user/password values above.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vanilla_api

# Required for PATCH /api/v1/admin/* endpoints.
ADMIN_API_KEY=replace-with-a-long-random-secret

ALLOWED_ORIGINS=http://localhost:5173

# Existing restaurant-wide Dub link. The API only retrieves its QR metadata;
# Dub remains responsible for the link, QR generation, and analytics.
# Create this in Dub workspace Settings > API Keys. Keep it backend-only.
DUB_API_KEY=
# Use the short-link hostname only (no https://), then the existing link slug.
DUB_DOMAIN=dub.sh
DUB_LINK_KEY=

# Public URL of this API. Image upload responses use it to return image_url.
PUBLIC_BASE_URL=http://localhost:8080

# Private S3-compatible image storage (SeaweedFS in production).
IMAGE_S3_ENDPOINT=http://localhost:8333
IMAGE_S3_REGION=us-east-1
IMAGE_S3_BUCKET=menu
IMAGE_S3_ACCESS_KEY=replace-with-a-bucket-scoped-access-key
IMAGE_S3_SECRET_KEY=replace-with-the-corresponding-secret-key
